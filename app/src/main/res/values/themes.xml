<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.OpenClawMobileAssistant"
        parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/toolbar_color</item>
        <item name="colorPrimaryVariant">@color/toolbar_color</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/send_button</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <!-- Allow layout to extend into display cutouts (corner notches) -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="popupMenuStyle">@style/DarkPopupMenu</item>
        <item name="android:popupMenuStyle">@style/DarkPopupMenu</item>
        <item name="actionOverflowMenuStyle">@style/DarkPopupMenu</item>
        <item name="android:panelBackground">@color/ai_bubble</item>
        <item name="android:colorBackground">@color/background</item>
    </style>
</resources>
