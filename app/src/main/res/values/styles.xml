<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- App Theme -->
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorSecondary">@color/accent</item>

        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>

        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <!-- Toolbar -->
    <style name="AppToolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/toolbar_color</item>
        <item name="titleTextColor">@color/text_primary</item>
        <item name="popupTheme">@style/ThemeOverlay.OpenClaw.PopupMenu</item>
    </style>

    <style name="TextAppearance.OpenClaw.ToolbarTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.OpenClaw.Message" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/message_text</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <style name="TextAppearance.OpenClaw.Timestamp" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/timestamp_text</item>
    </style>

    <style name="TextAppearance.OpenClaw.Status" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.OpenClaw.SectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.OpenClaw.SectionBody" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.OpenClaw.BodyReadable" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="TextAppearance.OpenClaw.CodeReadable" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:lineSpacingExtra">5dp</item>
    </style>

    <style name="TextAppearance.OpenClaw.NumericStat" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Popup Menu -->
    <style name="DarkPopupMenu" parent="Widget.MaterialComponents.PopupMenu">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:background">@color/ai_bubble</item>
        <item name="android:popupBackground">@color/ai_bubble</item>
    </style>

    <style name="ThemeOverlay.OpenClaw.PopupMenu" parent="ThemeOverlay.AppCompat.Dark">
        <item name="android:popupBackground">@color/ai_bubble</item>
        <item name="android:panelBackground">@color/ai_bubble</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="popupMenuStyle">@style/DarkPopupMenu</item>
        <item name="android:popupMenuStyle">@style/DarkPopupMenu</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <!-- Rounded Shape -->
    <style name="RoundedCorners">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.OpenClawMobileAssistant</item>
    </style>

    <style name="ShapeAppearanceOverlay.OpenClaw.UserBubble" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">18dp</item>
        <item name="cornerSizeTopRight">18dp</item>
        <item name="cornerSizeBottomLeft">18dp</item>
        <item name="cornerSizeBottomRight">18dp</item>
    </style>

    <style name="ShapeAppearanceOverlay.OpenClaw.AiBubble" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">4dp</item>
        <item name="cornerSizeTopRight">18dp</item>
        <item name="cornerSizeBottomLeft">18dp</item>
        <item name="cornerSizeBottomRight">18dp</item>
    </style>

    <style name="Widget.OpenClaw.AttachmentAction" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="iconTint">@color/text_secondary</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">12dp</item>
    </style>

    <style name="Widget.OpenClaw.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/send_button</item>
        <item name="iconTint">@color/white</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.OpenClaw.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/secondary_button_text</item>
        <item name="backgroundTint">@color/surface_container_low</item>
        <item name="iconTint">@color/text_primary</item>
        <item name="strokeColor">@color/outline_subtle</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.OpenClaw.Button.Danger" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/status_failed</item>
        <item name="iconTint">@color/white</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.OpenClaw.InputField" parent="">
        <item name="android:minHeight">@dimen/touch_target</item>
        <item name="android:background">@drawable/bg_chat_input</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:paddingLeft">@dimen/space_lg</item>
        <item name="android:paddingTop">@dimen/space_md</item>
        <item name="android:paddingRight">@dimen/space_lg</item>
        <item name="android:paddingBottom">@dimen/space_md</item>
    </style>

    <style name="Widget.OpenClaw.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">@dimen/radius_md</item>
        <item name="cardElevation">0dp</item>
    </style>

</resources>
