<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/background"
            android:minHeight="48dp"
            app:title="@string/toolbar_title"
            app:titleTextAppearance="@style/TextAppearance.OpenClaw.ToolbarTitle"
            app:navigationIconTint="@color/text_secondary"
            app:popupTheme="@style/ThemeOverlay.OpenClaw.PopupMenu"
            app:contentInsetStartWithNavigation="@dimen/space_lg"
            app:contentInsetStart="@dimen/space_lg"
            app:contentInsetEndWithActions="@dimen/space_sm"
            app:titleTextColor="@color/text_primary" />

        <LinearLayout
            android:id="@+id/headerStatusRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/space_lg"
            android:paddingTop="2dp"
            android:paddingEnd="@dimen/space_lg"
            android:paddingBottom="@dimen/space_sm">

            <TextView
                android:id="@+id/statusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_sm"
                android:layout_weight="1"
                android:background="@drawable/bg_status_chip"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:maxLines="2"
                android:minHeight="28dp"
                android:minWidth="0dp"
                android:paddingHorizontal="@dimen/space_md"
                android:paddingVertical="6dp"
                android:text="@string/chat_status_disconnected"
                android:textColor="@color/status_disconnected"
                android:textSize="12sp" />

            <FrameLayout
                android:id="@+id/agentSelectorContainer"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_agent_selector"
                android:minWidth="96dp"
                android:paddingStart="@dimen/space_md"
                android:paddingEnd="28dp">

                <Spinner
                    android:id="@+id/agentSpinner"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="center_vertical"
                    android:background="@android:color/transparent"
                    android:dropDownHorizontalOffset="-12dp"
                    android:gravity="center_vertical|end"
                    android:paddingEnd="@dimen/space_sm"
                    android:popupBackground="@color/ai_bubble"
                    android:spinnerMode="dropdown" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_chevron_down"
                    app:tint="@color/text_secondary" />
            </FrameLayout>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Dashboard summary cards (collapsed when chat is active) -->
        <HorizontalScrollView
            android:id="@+id/dashboardCardsScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingTop="@dimen/space_md"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Session count card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSessionCount"
                    android:layout_width="140dp"
                    android:layout_height="80dp"
                    android:layout_marginEnd="@dimen/space_md"
                    app:cardBackgroundColor="@color/md3_surface_variant"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="@dimen/space_md"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/sessionCountValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/md3_primary"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sessions"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Task completion rate card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTaskCompletion"
                    android:layout_width="140dp"
                    android:layout_height="80dp"
                    android:layout_marginEnd="@dimen/space_md"
                    app:cardBackgroundColor="@color/md3_surface_variant"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="@dimen/space_md"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/taskCompletionValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/status_completed"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Task completion"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Pending tasks card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPendingTasks"
                    android:layout_width="140dp"
                    android:layout_height="80dp"
                    app:cardBackgroundColor="@color/md3_surface_variant"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="@dimen/space_md"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/pendingTasksValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/status_pending"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pending tasks"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Alerts section -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAlerts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_sm"
            android:layout_marginBottom="@dimen/space_sm"
            app:cardBackgroundColor="@color/error_surface"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="0dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_md">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alerts"
                    android:textColor="@color/status_failed"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="@dimen/space_xs" />

                <TextView
                    android:id="@+id/alertsText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Offline banner -->
        <com.user.ui.components.OfflineBannerView
            android:id="@+id/offlineBanner"
            android:layout_width="match_parent"
            android:layout_height="@dimen/touch_target_min"
            android:background="@color/warning_surface"
            android:orientation="horizontal"
            android:visibility="gone" />

        <!-- Chat RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp" />

        <TextView
            android:id="@+id/typingIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="6dp"
            android:paddingHorizontal="4dp"
            android:paddingVertical="2dp"
            android:text="@string/typing_indicator"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- Bottom input bar -->
        <LinearLayout
            android:id="@+id/bottomBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/background"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_md"
            android:paddingTop="@dimen/space_sm"
            android:paddingBottom="@dimen/space_md">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/imagePreviewLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_chat_input"
                android:padding="8dp"
                android:visibility="gone">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imagePreviewImage"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:scaleType="centerCrop"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:shapeAppearanceOverlay="@style/RoundedCorners" />

                <TextView
                    android:id="@+id/imagePreviewText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/image_attached"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="@id/imagePreviewImage"
                    app:layout_constraintEnd_toStartOf="@id/removePreviewButton"
                    app:layout_constraintStart_toEndOf="@id/imagePreviewImage"
                    app:layout_constraintTop_toTopOf="@id/imagePreviewImage" />

                <ImageButton
                    android:id="@+id/removePreviewButton"
                    android:layout_width="@dimen/touch_target_min"
                    android:layout_height="@dimen/touch_target_min"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/remove_preview"
                    android:padding="12dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:layout_constraintBottom_toBottomOf="@id/imagePreviewImage"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/imagePreviewImage"
                    app:tint="@color/text_secondary" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:id="@+id/inputContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chat_input"
                android:gravity="center_vertical"
                android:minHeight="@dimen/button_height"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/space_sm"
                android:paddingVertical="@dimen/space_sm">

                <ImageButton
                    android:id="@+id/attachButton"
                    android:layout_width="@dimen/touch_target_min"
                    android:layout_height="@dimen/touch_target_min"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/more_options"
                    android:padding="12dp"
                    android:src="@drawable/ic_add"
                    app:tint="@color/text_secondary" />

                <ImageButton
                    android:id="@+id/voiceButton"
                    android:layout_width="@dimen/touch_target_min"
                    android:layout_height="@dimen/touch_target_min"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/voice_input"
                    android:padding="12dp"
                    android:src="@android:drawable/ic_btn_speak_now"
                    app:tint="@color/text_secondary" />

                <AutoCompleteTextView
                    android:id="@+id/messageEditText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:gravity="center_vertical|start"
                    android:hint="@string/message_hint_command"
                    android:inputType="textCapSentences|textMultiLine"
                    android:maxLines="4"
                    android:minHeight="@dimen/touch_target_min"
                    android:paddingStart="4dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="10dp"
                    android:scrollbars="vertical"
                    android:textColor="@color/input_text"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="14sp"
                    android:dropDownAnchor="@id/inputContainer"
                    android:dropDownVerticalOffset="4dp"
                    android:completionThreshold="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/sendButton"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/touch_target_min"
                    android:layout_marginStart="@dimen/space_xs"
                    android:minWidth="@dimen/touch_target_min"
                    android:text="@string/send_message"
                    android:paddingHorizontal="@dimen/space_lg" />
            </LinearLayout>
        </LinearLayout>

        <!-- Bottom NavigationBar (MD3) -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/navigationBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/md3_surface"
            android:visibility="gone"
            app:itemIconTint="@color/text_secondary"
            app:itemTextColor="@color/text_secondary"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/nav_menu_main" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
