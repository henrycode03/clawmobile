<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <ImageView
        android:id="@+id/offline_banner_icon"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="12dp"
        android:src="@android:drawable/ic_dialog_info"
        android:contentDescription="@string/offline_icon_description"
        tools:ignore="VectorDrawableCompat" />

    <TextView
        android:id="@+id/offline_banner_message"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="8dp"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        tools:text="Last updated 5 min ago — Tap to retry" />

    <TextView
        android:id="@+id/offline_banner_retry"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/touch_target_min"
        android:layout_gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:text="@string/retry"
        android:textColor="@color/md3_primary"
        android:textSize="12sp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true" />

</merge>
