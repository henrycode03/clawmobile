<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="4dp">

    <!-- AI row (left aligned) -->
    <LinearLayout
        android:id="@+id/aiRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start"
        android:visibility="gone">

        <!-- Avatar -->
        <TextView
            android:id="@+id/avatarText"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="🦞"
            android:textSize="20sp"
            android:gravity="center"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="4dp" />

        <!-- AI bubble -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bubble_ai"
            android:padding="10dp"
            android:layout_marginEnd="48dp">

            <!-- Text message -->
            <TextView
                android:id="@+id/messageText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/message_text"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.3"
                android:visibility="gone" />

            <!-- Image (Base64 or URL) -->
            <ImageView
                android:id="@+id/messageImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:maxHeight="400dp"
                android:scaleType="fitStart"
                android:layout_marginTop="4dp"
                android:visibility="gone" />

            <!-- Timestamp -->
            <TextView
                android:id="@+id/timestampText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#888888"
                android:layout_gravity="end"
                android:layout_marginTop="4dp" />

        </LinearLayout>
    </LinearLayout>

    <!-- User row (right aligned) -->
    <LinearLayout
        android:id="@+id/userRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bubble_user"
            android:padding="10dp"
            android:layout_marginStart="48dp">

            <ImageView
                android:id="@+id/userMessageImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:maxHeight="300dp"
                android:scaleType="fitStart"
                android:layout_marginBottom="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/userMessageText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/message_text"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.3" />

            <TextView
                android:id="@+id/userTimestampText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#808080"
                android:layout_gravity="end"
                android:layout_marginTop="4dp" />

        </LinearLayout>
    </LinearLayout>

</LinearLayout>



