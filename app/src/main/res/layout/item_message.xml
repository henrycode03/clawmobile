<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="4dp">

    <!-- AI message row (avatar + bubble) -->
    <LinearLayout
        android:id="@+id/aiRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start"
        android:visibility="gone">

        <!-- AI avatar -->
        <TextView
            android:id="@+id/aiAvatar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="🦞"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/messageText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="280dp"
                android:textSize="16sp"
                android:textColor="@color/ai_bubble_text"
                android:background="@drawable/bubble_ai"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:lineSpacingMultiplier="1.3" />

            <TextView
                android:id="@+id/timestampText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/timestamp_text"
                android:paddingTop="3dp"
                android:paddingStart="4dp" />
        </LinearLayout>

        <!-- spacer to keep bubble from stretching full width -->
        <View
            android:layout_width="56dp"
            android:layout_height="1dp" />

    </LinearLayout>

    <!-- User message row (bubble only, aligned right) -->
    <LinearLayout
        android:id="@+id/userRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:visibility="gone">

        <!-- spacer -->
        <View
            android:layout_width="56dp"
            android:layout_height="1dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/userMessageText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="280dp"
                android:textSize="16sp"
                android:textColor="@color/user_bubble_text"
                android:background="@drawable/bubble_user"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:lineSpacingMultiplier="1.3" />

            <TextView
                android:id="@+id/userTimestampText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/timestamp_text"
                android:paddingTop="3dp"
                android:paddingEnd="4dp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>

