<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/taskListScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        android:orientation="vertical">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/toolbar_color"
            app:popupTheme="@style/ThemeOverlay.OpenClaw.PopupMenu"
            app:titleTextColor="@color/text_primary"
            app:navigationIcon="@drawable/ic_back"/>

        <EditText
            android:id="@+id/searchInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_md"
            android:layout_marginEnd="@dimen/space_lg"
            android:background="@drawable/bg_chat_input"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="@dimen/space_md"
            android:hint="Search projects or tasks"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:minHeight="48dp"
            android:paddingStart="@dimen/space_lg"
            android:paddingTop="@dimen/space_md"
            android:paddingEnd="@dimen/space_lg"
            android:paddingBottom="@dimen/space_md"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_md"
            android:layout_marginEnd="@dimen/space_lg"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                app:chipSpacingHorizontal="@dimen/space_sm">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBrowseSessions"
                    style="@style/Widget.Material3.Chip.Suggestion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="false"
                    android:text="@string/task_hub_jump_sessions" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBrowseProjects"
                    style="@style/Widget.Material3.Chip.Suggestion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="false"
                    android:text="@string/task_hub_jump_projects" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBrowseTasks"
                    style="@style/Widget.Material3.Chip.Suggestion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="false"
                    android:text="@string/task_hub_jump_tasks" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- Status Filter Chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_md"
            android:layout_marginEnd="@dimen/space_lg"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/taskStatusChipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAll"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/status_chip_height"
                    android:text="All"
                    android:checked="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPending"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/status_chip_height"
                    android:text="Pending" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRunning"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/status_chip_height"
                    android:text="Running" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDone"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/status_chip_height"
                    android:text="Done" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFailed"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/status_chip_height"
                    android:text="Failed" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- Dashboard Stats Grid -->
        <androidx.cardview.widget.CardView
            android:id="@+id/statsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_lg"
            android:layout_marginEnd="@dimen/space_lg"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_lg">

                <!-- Row 1: Projects and Tasks -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Total Projects -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingEnd="8dp">

                        <TextView
                            android:id="@+id/totalProjectsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/primary"
                            android:textSize="28sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Projects"
                            android:textColor="@color/card_text_secondary"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <!-- Total Tasks -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingStart="8dp">

                        <TextView
                            android:id="@+id/totalTasksCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/blue_500"
                            android:textSize="28sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tasks"
                            android:textColor="@color/card_text_secondary"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginVertical="@dimen/space_md"/>

                <!-- Row 2: Running, Pending, Completed -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- Running -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/runningCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/status_running"
                            android:textSize="24sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Running"
                            android:textColor="@color/card_text_secondary"
                            android:textSize="11sp"/>
                    </LinearLayout>

                    <!-- Pending -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/pendingCountNew"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/status_pending"
                            android:textSize="24sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pending"
                            android:textColor="@color/card_text_secondary"
                            android:textSize="11sp"/>
                    </LinearLayout>

                    <!-- Completed -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/completedCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/status_completed"
                            android:textSize="24sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Done"
                            android:textColor="@color/card_text_secondary"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Overview Section -->
        <androidx.cardview.widget.CardView
            android:id="@+id/executionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_md"
            android:layout_marginEnd="@dimen/space_lg"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/task_hub_sessions_title"
                        android:textColor="@color/card_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/openSessionsButton"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="0dp"
                        android:text="@string/task_hub_sessions_all" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:text="@string/task_hub_sessions_subtitle"
                    android:textColor="@color/card_text_secondary"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/executionSummaryView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:text="No recent execution data yet"
                    android:textColor="@color/card_text_primary"
                    android:textSize="15sp"/>

                <TextView
                    android:id="@+id/recentActivityView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:lineSpacingExtra="2dp"
                    android:maxLines="3"
                    android:text="Open a project to inspect logs, status, and task details."
                    android:textColor="@color/card_text_secondary"
                    android:textSize="13sp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="@dimen/space_lg"
                    android:background="@color/divider"/>

                <TextView
                    android:id="@+id/latestFailureView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_lg"
                    android:background="@drawable/bg_overview_panel"
                    android:padding="@dimen/space_md"
                    android:text="Latest failure will appear here."
                    android:textColor="@color/card_text_primary"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/runningSessionView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:background="@drawable/bg_overview_panel"
                    android:padding="@dimen/space_md"
                    android:text="Running session will appear here."
                    android:textColor="@color/card_text_primary"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/resumableSessionView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:background="@drawable/bg_overview_panel"
                    android:padding="@dimen/space_md"
                    android:text="Resumable session will appear here."
                    android:textColor="@color/card_text_primary"
                    android:textSize="13sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/blockersCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_md"
            android:layout_marginEnd="@dimen/space_lg"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Blockers"
                    android:textColor="@color/card_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/blockerSummaryView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:text="No blockers detected."
                    android:textColor="@color/card_text_primary"
                    android:textSize="15sp"/>

                <TextView
                    android:id="@+id/blockerDetailsView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:lineSpacingExtra="2dp"
                    android:maxLines="4"
                    android:text="Runs that need attention will appear here."
                    android:textColor="@color/card_text_secondary"
                    android:textSize="13sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/projectsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_md"
            android:layout_marginEnd="@dimen/space_lg"
            android:layout_marginBottom="@dimen/space_sm"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/task_hub_projects_title"
                    android:textColor="@color/card_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:text="@string/task_hub_projects_subtitle"
                    android:textColor="@color/card_text_secondary"
                    android:textSize="13sp"/>

                <!-- Project List -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/projectsRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:nestedScrollingEnabled="false"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Orchestrator Stats / Warning Display -->
        <TextView
            android:id="@+id/orchestratorStatsView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_md"
            android:layout_marginEnd="@dimen/space_lg"
            android:padding="@dimen/space_md"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:background="@color/primary_dark"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/orchestratorHelpView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_sm"
            android:layout_marginEnd="@dimen/space_lg"
            android:background="@drawable/bg_chat_input"
            android:padding="@dimen/space_md"
            android:text="Local browsing remains available."
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:visibility="gone"/>

        <LinearLayout
            android:id="@+id/tasksSectionHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_xl"
            android:layout_marginEnd="@dimen/space_lg"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/task_hub_tasks_title"
                android:textColor="@color/card_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:text="@string/task_hub_tasks_subtitle"
                android:textColor="@color/card_text_secondary"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Empty State -->
        <TextView
            android:id="@+id/emptyView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_2xl"
            android:layout_marginEnd="@dimen/space_lg"
            android:layout_marginBottom="@dimen/space_2xl"
            android:gravity="center"
            android:padding="@dimen/space_lg"
            android:text="No tasks available"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:visibility="gone"/>

        <!-- Sequence indicator -->
        <TextView
            android:id="@+id/sequenceIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_lg"
            android:layout_marginEnd="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_sm"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:gravity="end"
            android:visibility="gone" />

        <!-- Task List RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:visibility="gone"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
