<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/toolbar_color"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_lg">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg">

                    <TextView
                        style="@style/TextAppearance.OpenClaw.SectionTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_gateway_title" />

                    <TextView
                        style="@style/TextAppearance.OpenClaw.SectionBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:text="@string/settings_server_url_desc" />

                    <TextView
                        style="@style/TextAppearance.OpenClaw.Status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_lg"
                        android:text="@string/settings_server_url" />

                    <EditText
                        android:id="@+id/serverUrlInput"
                        style="@style/Widget.OpenClaw.InputField"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:autofillHints="none"
                        android:hint="@string/settings_server_url_hint"
                        android:inputType="textUri"
                        android:singleLine="true" />

                    <TextView
                        style="@style/TextAppearance.OpenClaw.Status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_lg"
                        android:text="@string/settings_gateway_token" />

                    <EditText
                        android:id="@+id/gatewayTokenInput"
                        style="@style/Widget.OpenClaw.InputField"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:autofillHints="none"
                        android:hint="@string/settings_gateway_token_hint"
                        android:inputType="textPassword"
                        android:singleLine="true" />

                    <TextView
                        style="@style/TextAppearance.OpenClaw.SectionBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:text="@string/settings_gateway_token_desc" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/orchestratorSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_lg"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="@dimen/radius_md"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_lg">

                        <TextView
                            style="@style/TextAppearance.OpenClaw.SectionTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_orchestrator_dashboard_title" />

                        <TextView
                            style="@style/TextAppearance.OpenClaw.SectionBody"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:text="@string/settings_orchestrator_desc" />

                        <TextView
                            style="@style/TextAppearance.OpenClaw.Status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_lg"
                            android:text="@string/settings_orchestrator_url" />

                        <EditText
                            android:id="@+id/orchestratorServerUrlInput"
                            style="@style/Widget.OpenClaw.InputField"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:autofillHints="none"
                            android:hint="@string/settings_orchestrator_server_url_hint"
                            android:inputType="textUri|textNoSuggestions"
                            android:singleLine="true" />

                        <TextView
                            style="@style/TextAppearance.OpenClaw.Status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_lg"
                            android:text="@string/settings_orchestrator_api_key" />

                        <EditText
                            android:id="@+id/orchestratorApiKeyInput"
                            style="@style/Widget.OpenClaw.InputField"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:autofillHints="none"
                            android:hint="@string/settings_orchestrator_api_key_hint"
                            android:inputType="textPassword"
                            android:singleLine="true" />

                        <TextView
                            style="@style/TextAppearance.OpenClaw.SectionBody"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:text="@string/settings_orchestrator_api_key_desc" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_lg"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/orchestratorTestButton"
                                style="@style/Widget.OpenClaw.Button.Secondary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_orchestrator_test" />

                            <TextView
                                android:id="@+id/orchestratorTestStatus"
                                style="@style/TextAppearance.OpenClaw.Status"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/space_md"
                                android:layout_weight="1"
                                android:visibility="gone" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg">

                    <TextView
                        style="@style/TextAppearance.OpenClaw.SectionTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_github_title" />

                    <TextView
                        style="@style/TextAppearance.OpenClaw.SectionBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:text="@string/settings_github_desc" />

                    <TextView
                        style="@style/TextAppearance.OpenClaw.Status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_lg"
                        android:text="@string/settings_github_token" />

                    <EditText
                        android:id="@+id/githubTokenInput"
                        style="@style/Widget.OpenClaw.InputField"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:autofillHints="none"
                        android:hint="@string/settings_github_token_hint"
                        android:inputType="textPassword"
                        android:singleLine="true" />

                    <TextView
                        style="@style/TextAppearance.OpenClaw.SectionBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:text="@string/settings_github_token_desc" />

                    <TextView
                        style="@style/TextAppearance.OpenClaw.Status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_lg"
                        android:text="@string/settings_github_api_url" />

                    <EditText
                        android:id="@+id/githubApiUrlInput"
                        style="@style/Widget.OpenClaw.InputField"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:autofillHints="none"
                        android:hint="@string/settings_github_api_url_hint"
                        android:inputType="textUri"
                        android:singleLine="true" />

                    <TextView
                        style="@style/TextAppearance.OpenClaw.Status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_lg"
                        android:text="@string/settings_github_repo" />

                    <EditText
                        android:id="@+id/githubDefaultRepoInput"
                        style="@style/Widget.OpenClaw.InputField"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:autofillHints="none"
                        android:hint="@string/settings_github_repo_hint"
                        android:inputType="text"
                        android:singleLine="true" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveButton"
                style="@style/Widget.OpenClaw.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:layout_marginBottom="@dimen/space_2xl"
                android:text="@string/settings_save" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
