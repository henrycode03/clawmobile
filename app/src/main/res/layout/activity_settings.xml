<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/toolbar_color"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Server Settings -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="488dp"
                android:layout_gravity="center_horizontal"
                android:text="@string/settings_gateway_title"
                android:textColor="@color/ai_bubble_text"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="488dp"
                android:layout_gravity="center_horizontal"
                android:text="@string/settings_server_url"
                android:textColor="@color/timestamp_text"
                android:textSize="12sp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/serverUrlInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="488dp"
                android:layout_gravity="center_horizontal"
                android:minHeight="48dp"
                android:hint="@string/settings_server_url_hint"
                android:autofillHints="none"
                android:textColorHint="@color/timestamp_text"
                android:textColor="@color/ai_bubble_text"
                android:inputType="textUri"
                android:singleLine="true"
                android:backgroundTint="@color/timestamp_text" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="488dp"
                android:layout_gravity="center_horizontal"
                android:text="@string/settings_server_url_desc"
                android:textColor="@color/timestamp_text"
                android:textSize="12sp"
                android:paddingTop="4dp"
                android:paddingBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="488dp"
                android:layout_gravity="center_horizontal"
                android:text="@string/settings_gateway_token"
                android:textColor="@color/timestamp_text"
                android:textSize="12sp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/gatewayTokenInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="488dp"
                android:layout_gravity="center_horizontal"
                android:minHeight="48dp"
                android:hint="@string/settings_gateway_token_hint"
                android:autofillHints="none"
                android:textColorHint="@color/timestamp_text"
                android:textColor="@color/ai_bubble_text"
                android:inputType="textPassword"
                android:singleLine="true"
                android:backgroundTint="@color/timestamp_text" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="488dp"
                android:layout_gravity="center_horizontal"
                android:text="@string/settings_gateway_token_desc"
                android:textColor="@color/timestamp_text"
                android:textSize="12sp"
                android:paddingTop="4dp"
                android:paddingBottom="24dp" />

            <!-- Orchestrator Integration - Standalone section -->
            <LinearLayout
                android:id="@+id/orchestratorSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="24dp"
                android:visibility="visible">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxWidth="488dp"
                    android:layout_gravity="center_horizontal"
                    android:text="@string/settings_orchestrator_dashboard_title"
                    android:textColor="@color/ai_bubble_text"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:paddingBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxWidth="488dp"
                    android:layout_gravity="center_horizontal"
                    android:text="@string/settings_orchestrator_url"
                    android:textColor="@color/timestamp_text"
                    android:textSize="12sp"
                    android:paddingBottom="4dp" />

                <EditText
                    android:id="@+id/orchestratorServerUrlInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxWidth="488dp"
                    android:minHeight="48dp"
                    android:layout_gravity="center_horizontal"
                    android:hint="@string/settings_orchestrator_server_url_hint"
                    android:autofillHints="none"
                    android:textColorHint="@color/timestamp_text"
                    android:textColor="@color/ai_bubble_text"
                    android:inputType="textUri"
                    android:singleLine="true"
                    android:backgroundTint="@color/timestamp_text" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxWidth="488dp"
                    android:layout_gravity="center_horizontal"
                    android:text="@string/settings_orchestrator_api_key_desc"
                    android:textColor="@color/timestamp_text"
                    android:textSize="12sp"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp" />

                <EditText
                    android:id="@+id/orchestratorApiKeyInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxWidth="488dp"
                    android:minHeight="48dp"
                    android:layout_gravity="center_horizontal"
                    android:hint="@string/settings_orchestrator_api_key_hint"
                    android:autofillHints="none"
                    android:textColorHint="@color/timestamp_text"
                    android:textColor="@color/ai_bubble_text"
                    android:inputType="textPassword"
                    android:singleLine="true"
                    android:backgroundTint="@color/timestamp_text" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxWidth="488dp"
                    android:layout_gravity="center_horizontal"
                    android:text="@string/settings_orchestrator_desc"
                    android:textColor="@color/timestamp_text"
                    android:textSize="12sp"
                    android:paddingTop="4dp"
                    android:paddingBottom="8dp" />

            </LinearLayout>

            <!-- GitHub Integration -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="488dp"
                android:layout_gravity="center_horizontal"
                android:text="@string/settings_github_title"
                android:textColor="@color/ai_bubble_text"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="488dp"
                android:layout_gravity="center_horizontal"
                android:text="@string/settings_github_token"
                android:textColor="@color/timestamp_text"
                android:textSize="12sp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/githubTokenInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="488dp"
                android:layout_gravity="center_horizontal"
                android:minHeight="48dp"
                android:hint="@string/settings_github_token_hint"
                android:autofillHints="none"
                android:textColorHint="@color/timestamp_text"
                android:textColor="@color/ai_bubble_text"
                android:inputType="textPassword"
                android:singleLine="true"
                android:backgroundTint="@color/timestamp_text" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="488dp"
                android:layout_gravity="center_horizontal"
                android:text="@string/settings_github_token_desc"
                android:textColor="@color/timestamp_text"
                android:textSize="12sp"
                android:paddingTop="4dp"
                android:paddingBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="488dp"
                android:layout_gravity="center_horizontal"
                android:text="@string/settings_github_api_url"
                android:textColor="@color/timestamp_text"
                android:textSize="12sp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/githubApiUrlInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="488dp"
                android:layout_gravity="center_horizontal"
                android:minHeight="48dp"
                android:hint="@string/settings_github_api_url_hint"
                android:autofillHints="none"
                android:textColorHint="@color/timestamp_text"
                android:textColor="@color/ai_bubble_text"
                android:inputType="textUri"
                android:singleLine="true"
                android:backgroundTint="@color/timestamp_text" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="488dp"
                android:layout_gravity="center_horizontal"
                android:text="@string/settings_github_repo"
                android:textColor="@color/timestamp_text"
                android:textSize="12sp"
                android:paddingTop="16dp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/githubDefaultRepoInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="488dp"
                android:layout_gravity="center_horizontal"
                android:hint="@string/settings_github_repo_hint"
                android:autofillHints="none"
                android:textColorHint="@color/timestamp_text"
                android:textColor="@color/ai_bubble_text"
                android:inputType="text"
                android:singleLine="true"
                android:backgroundTint="@color/timestamp_text" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="488dp"
                android:layout_gravity="center_horizontal"
                android:text="@string/settings_github_desc"
                android:textColor="@color/timestamp_text"
                android:textSize="12sp"
                android:paddingTop="8dp"
                android:paddingBottom="24dp" />

            <Button
                android:id="@+id/saveButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:minWidth="200dp"
                android:maxWidth="320dp"
                android:text="@string/settings_save"
                android:backgroundTint="@color/send_button"
                android:textColor="@color/white" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>