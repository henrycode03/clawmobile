<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/toolbar_color"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_lg">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg">

                    <TextView
                        style="@style/TextAppearance.OpenClaw.SectionTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/github_repository_title" />

                    <TextView
                        style="@style/TextAppearance.OpenClaw.SectionBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:text="@string/github_repository_subtitle" />

                    <TextView
                        android:id="@+id/repoInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:background="@drawable/bg_github_result_panel"
                        android:padding="@dimen/space_md"
                        android:text="No repository selected"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/refreshButton"
                        style="@style/Widget.OpenClaw.Button.Secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/github_refresh_repos" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg">

                    <TextView
                        style="@style/TextAppearance.OpenClaw.SectionTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/github_pull_requests_title" />

                    <TextView
                        style="@style/TextAppearance.OpenClaw.SectionBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:text="@string/github_pull_requests_subtitle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/showPrsButton"
                        style="@style/Widget.OpenClaw.Button.Primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/github_show_prs" />

                    <EditText
                        android:id="@+id/prList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:minHeight="140dp"
                        android:background="@drawable/bg_github_result_panel"
                        android:clickable="false"
                        android:focusable="false"
                        android:gravity="top|start"
                        android:hint="@string/github_prs_hint"
                        android:inputType="textMultiLine"
                        android:padding="@dimen/space_md"
                        android:scrollbars="vertical"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textIsSelectable="true" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg">

                    <TextView
                        style="@style/TextAppearance.OpenClaw.SectionTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/github_issues_title" />

                    <TextView
                        style="@style/TextAppearance.OpenClaw.SectionBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:text="@string/github_issues_subtitle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/showIssuesButton"
                        style="@style/Widget.OpenClaw.Button.Secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/github_show_issues" />

                    <EditText
                        android:id="@+id/issueList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:minHeight="140dp"
                        android:background="@drawable/bg_github_result_panel"
                        android:clickable="false"
                        android:focusable="false"
                        android:gravity="top|start"
                        android:hint="@string/github_issues_hint"
                        android:inputType="textMultiLine"
                        android:padding="@dimen/space_md"
                        android:scrollbars="vertical"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textIsSelectable="true" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg">

                    <TextView
                        style="@style/TextAppearance.OpenClaw.SectionTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/github_commit_lookup_title" />

                    <TextView
                        style="@style/TextAppearance.OpenClaw.SectionBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:text="@string/github_commit_lookup_subtitle" />

                    <EditText
                        android:id="@+id/commitIdInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:background="@drawable/bg_github_result_panel"
                        android:hint="@string/github_commit_hint"
                        android:inputType="text"
                        android:minHeight="@dimen/touch_target"
                        android:padding="@dimen/space_md"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/showCommitButton"
                        style="@style/Widget.OpenClaw.Button.Secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/github_show_commit" />

                    <EditText
                        android:id="@+id/commitInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:minHeight="140dp"
                        android:background="@drawable/bg_github_result_panel"
                        android:clickable="false"
                        android:focusable="false"
                        android:gravity="top|start"
                        android:hint="@string/github_commit_result_hint"
                        android:inputType="textMultiLine"
                        android:padding="@dimen/space_md"
                        android:scrollbars="vertical"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textIsSelectable="true" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <ProgressBar
                android:id="@+id/loadingIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/space_lg"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:text="@string/github_saved_connections_title"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                style="@style/TextAppearance.OpenClaw.SectionBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:text="@string/github_saved_connections_subtitle" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:layout_marginBottom="@dimen/space_2xl"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md">

                    <TextView
                        android:id="@+id/emptyView"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="No connections"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/repo_recycler_view"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxHeight="180dp"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
